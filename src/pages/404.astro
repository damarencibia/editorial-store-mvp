---
import StoreLayout from '../layouts/StoreLayout.astro'
---

<StoreLayout>
  <title>Editorial — Página no encontrada</title>
  <meta property="og:title" slot="head" content="Editorial — Página no encontrada" />

  <div class="flex flex-col items-center justify-center py-24 text-center">
    <span class="font-heading text-8xl font-bold text-accent/20">404</span>
    <h1 class="font-heading text-3xl font-bold tracking-tight mt-4">Página no encontrada</h1>
    <p class="text-text-muted mt-3 max-w-md">
      La página que buscas no existe o ha sido movida.
    </p>
    <a
      href="/"
      class="mt-8 inline-flex items-center gap-2 rounded-lg bg-accent px-6 py-2.5 text-sm font-medium text-white hover:bg-accent/90 transition-all duration-200"
    >
      Volver al inicio
    </a>
  </div>
</StoreLayout>
