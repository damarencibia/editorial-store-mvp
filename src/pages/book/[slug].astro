---
import Layout from '../../layouts/Layout.astro'
import AddToCartButton from '../../components/AddToCartButton.vue'
import { supabase } from '../../lib/supabase'

const { slug } = Astro.params

const { data: book } = await supabase
  .from('books')
  .select('*')
  .eq('slug', slug)
  .single()

if (!book) {
  return Astro.redirect('/404')
}

const formattedPrice = `$${(book.price / 100).toFixed(2)}`
---

<Layout>
  <article class="grid md:grid-cols-[400px_1fr] gap-8 lg:gap-12">
    <div class="aspect-[2/3] overflow-hidden rounded-xl bg-gray-100 shadow-md mx-auto md:mx-0 max-w-[400px] w-full">
      <img
        src={book.cover_url}
        alt={book.title}
        class="h-full w-full object-cover"
      />
    </div>

    <div class="flex flex-col gap-6">
      <div>
        <p class="text-sm text-gray-500 mb-1">{book.author}</p>
        <h1 class="text-3xl font-bold tracking-tight">{book.title}</h1>
      </div>

      <p class="text-2xl font-bold text-indigo-600">{formattedPrice}</p>

      <p class="text-gray-600 leading-relaxed">{book.description}</p>

      <AddToCartButton
        client:load
        bookId={book.id}
        slug={book.slug}
        title={book.title}
        author={book.author}
        price={book.price}
        coverUrl={book.cover_url}
      />

      <a
        href="/"
        class="text-sm text-gray-500 hover:text-indigo-600 transition-colors"
      >
        ← Back to catalog
      </a>
    </div>
  </article>
</Layout>
