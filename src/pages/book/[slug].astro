---
import StoreLayout from '../../layouts/StoreLayout.astro'
import AddToCartButton from '../../components/store/AddToCartButton.vue'
import { supabase } from '../../lib/supabase'

const { slug } = Astro.params

const { data: book } = await supabase
  .from('books')
  .select('*, categories(name, collection_id), series(name), authors!left(name, slug, photo_url, bio)')
  .eq('slug', slug)
  .single()

let collectionName: string | null = null
if (book?.categories?.collection_id) {
  const { data: col } = await supabase
    .from('collections')
    .select('name')
    .eq('id', book.categories.collection_id)
    .single()
  collectionName = col?.name ?? null
}

if (!book) {
  return Astro.redirect('/404')
}

const formattedPrice = `$${(book.price / 100).toFixed(2)}`
---

<StoreLayout>
  <title>{book.title} — Arraigo Editorial</title>
  <meta property="og:title" slot="head" content={`${book.title} — Arraigo Editorial`} />
  <meta property="og:description" slot="head" content={book.description ?? ''} />
  <meta property="og:type" slot="head" content="book" />
  {book.cover_url && <meta property="og:image" slot="head" content={book.cover_url} />}

  <article class="grid md:grid-cols-[400px_1fr] gap-8 lg:gap-12">
    <div class="flex flex-col gap-6 max-w-[400px] mx-auto md:mx-0 w-full">
      <div class="aspect-[2/3] overflow-hidden rounded-lg bg-surface-2 border border-border animate-in">
        <img
          src={book.cover_url}
          alt={book.title}
          class="h-full w-full object-cover"
        />
      </div>
    </div>

    <div class="flex flex-col gap-6 animate-in">
      <div>
        <p class="text-sm text-text-muted mb-1">{book.authors?.name ?? ''}</p>
        <h1 class="font-heading text-3xl sm:text-4xl font-bold tracking-tight">{book.title}</h1>
      </div>

      {book.subtitle && (
        <p class="text-sm italic text-text-muted/70 leading-relaxed -mt-2">{book.subtitle}</p>
      )}

      <p class="text-text-muted leading-relaxed">{book.description}</p>

      <details class="border-t border-border pt-4 group open:pb-2">
        <summary class="cursor-pointer list-none flex items-center justify-between text-sm font-medium text-text-primary hover:text-accent transition-colors select-none">
          <span>
            Descripción de {book.title}
            {book.series?.name && <span class="text-text-muted font-normal"> ({book.series?.name})</span>}
          </span>
          <svg class="w-4 h-4 transition-transform group-open:rotate-180 text-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
          </svg>
        </summary>
        <div class="mt-4 space-y-0 text-sm divide-y divide-border/50">
          <div class="flex justify-between py-2">
            <span class="text-text-muted">Colección</span>
            <span class="text-text-primary font-medium">{collectionName ?? (book.categories?.name ?? '-')}</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-text-muted">Páginas</span>
            <span class="text-text-primary font-medium">{book.pages}</span>
          </div>
          {book.translator && <div class="flex justify-between py-2">
            <span class="text-text-muted">Traductor</span>
            <span class="text-text-primary font-medium">{book.translator}</span>
          </div>}
          {book.series?.name && <div class="flex justify-between py-2">
            <span class="text-text-muted">Serie / Saga</span>
            <span class="text-text-primary font-medium">{book.series?.name}</span>
          </div>}
          <div class="flex justify-between py-2">
            <span class="text-text-muted">Público objetivo</span>
            <span class="text-text-primary font-medium">{book.age_target}</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-text-muted">Encuadernación</span>
            <span class="text-text-primary font-medium">{book.binding_type}</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-text-muted">Idioma</span>
            <span class="text-text-primary font-medium">{book.language}</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-text-muted">Autor</span>
            <span class="text-text-primary font-medium">{book.authors?.name ?? '-'}</span>
          </div>
          <div class="flex justify-between py-2">
            <span class="text-text-muted">Editorial</span>
            <span class="text-text-primary font-medium">{book.publisher ?? '-'}</span>
          </div>
        </div>
      </details>

      <p class="text-2xl font-bold text-accent">{formattedPrice}</p>

      <AddToCartButton
        client:only="vue"
        bookId={book.id}
        slug={book.slug}
        title={book.title}
        author={book.authors?.name ?? ''}
        price={book.price}
        coverUrl={book.cover_url}
      />

      {book.authors && (
        <div class="flex items-start gap-3 pb-2 animate-in">
          <a href={`/autor/${book.authors.slug}`} class="w-11 h-11 rounded-full overflow-hidden flex-shrink-0 mt-0.5">
            {book.authors.photo_url ? (
              <img
                src={book.authors.photo_url}
                alt={book.authors.name}
                class="h-full w-full object-cover"
              />
            ) : (
              <span class="h-full w-full bg-surface-3 flex items-center justify-center text-sm text-text-muted">
                {book.authors.name.charAt(0).toUpperCase()}
              </span>
            )}
          </a>
          <div class="min-w-0">
            <a href={`/autor/${book.authors.slug}`} class="hover:text-accent transition-colors">
              <p class="text-sm font-medium text-text-primary">{book.authors.name}</p>
            </a>
            {book.authors.bio && (
              <details class="group">
                <summary class="text-xs text-text-muted leading-relaxed cursor-pointer marker:hidden list-none [&::-webkit-details-marker]:hidden">
                  <span class="line-clamp-3 group-open:line-clamp-none">{book.authors.bio}</span>
                  <span class="text-accent hover:text-accent/80 text-xs font-medium mt-0.5 inline-block transition-colors">Leer más</span>
                </summary>
              </details>
            )}
          </div>
        </div>
      )}

      <a
        href="/"
        class="text-sm text-text-muted hover:text-accent transition-colors inline-flex items-center gap-1"
      >
        &larr; Back to catalog
      </a>
    </div>
  </article>
</StoreLayout>
