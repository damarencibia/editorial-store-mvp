---
import StoreLayout from '../../layouts/StoreLayout.astro'
import { getServerSupabase } from '../../lib/auth'

const supabase = getServerSupabase(Astro.cookies as any)
const { data: { session } } = await supabase.auth.getSession()

if (!session) {
  return Astro.redirect('/auth/login')
}

const user = session.user
---

<StoreLayout>
  <title>Mi perfil — Editorial</title>

  <div class="max-w-2xl mx-auto">
    <h1 class="font-heading text-2xl font-bold tracking-tight mb-8">Mi perfil</h1>

    <div class="rounded-lg border border-border bg-surface-2 p-6 space-y-4">
      <div>
        <p class="text-xs text-text-muted uppercase tracking-wider font-semibold">Email</p>
        <p class="text-sm mt-1">{user.email}</p>
      </div>

      <div>
        <p class="text-xs text-text-muted uppercase tracking-wider font-semibold">ID</p>
        <p class="text-sm mt-1 font-mono text-text-dim">{user.id}</p>
      </div>

      <div>
        <p class="text-xs text-text-muted uppercase tracking-wider font-semibold">Último acceso</p>
        <p class="text-sm mt-1">{session.created_at ? new Date(session.created_at).toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }) : '-'}</p>
      </div>
    </div>

    <div class="mt-6">
      <form method="POST" action="/api/auth/signout">
        <button
          type="submit"
          class="cursor-pointer rounded-lg border border-border px-4 py-2 text-sm text-text-muted hover:text-text-primary hover:border-border-hover transition-colors"
        >
          Cerrar sesión
        </button>
      </form>
    </div>
  </div>
</StoreLayout>
