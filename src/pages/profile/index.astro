---
import StoreLayout from '../../layouts/StoreLayout.astro'
import ProfileForm from '../../components/store/ProfileForm.vue'
import { getServerSupabase } from '../../lib/auth'
import { getServerProfile } from '../../lib/profiles'

const supabase = getServerSupabase(Astro.request, (name, value, options) => {
  Astro.cookies.set(name, value, options as any)
})
const { data: { user } } = await supabase.auth.getUser()

if (!user) {
  return Astro.redirect('/auth/login')
}

const profile = await getServerProfile(supabase)
const isAdmin = profile?.role === 'admin'

const { data: recentOrders } = await supabase
  .from('orders')
  .select('*')
  .eq('user_id', user.id)
  .order('created_at', { ascending: false })
  .limit(5)

function formatPrice(cents: number): string {
  return '$' + (cents / 100).toFixed(2)
}

const statusLabels: Record<string, string> = {
  pending: 'Pendiente',
  paid: 'Pagado',
  shipped: 'Enviado',
  cancelled: 'Cancelado',
}

const statusColors: Record<string, string> = {
  pending: 'text-yellow-400',
  paid: 'text-green-400',
  shipped: 'text-blue-400',
  cancelled: 'text-red-400',
}
---

<StoreLayout>
  <title>Mi perfil — Arraigo Editorial</title>

  <div class="max-w-2xl mx-auto">
    <h1 class="font-heading text-2xl font-bold tracking-tight mb-8">Mi perfil</h1>

    <div class="rounded-lg border border-border bg-surface-2 p-6 space-y-4">
      <div class="flex items-center justify-between">
        <div>
          <p class="text-xs text-text-muted uppercase tracking-wider font-semibold">Email</p>
          <p class="text-sm mt-1">{user.email}</p>
        </div>
        {isAdmin && (
          <span class="inline-flex items-center rounded-full bg-accent/10 px-3 py-1 text-xs font-medium text-accent">
            Admin
          </span>
        )}
      </div>

      {profile?.full_name && (
        <div>
          <p class="text-xs text-text-muted uppercase tracking-wider font-semibold">Nombre</p>
          <p class="text-sm mt-1">{profile.full_name}</p>
        </div>
      )}

    </div>

    <div class="mt-8">
      <ProfileForm client:only="vue" />
    </div>

    {
      recentOrders && recentOrders.length > 0 && (
        <div class="mt-10">
          <div class="flex items-center justify-between mb-4">
            <h2 class="font-heading text-lg font-semibold">Pedidos recientes</h2>
            <a href="/orders" class="text-xs text-accent hover:text-accent/80 transition-colors">Ver todos &rarr;</a>
          </div>
          <div class="rounded-lg border border-border divide-y divide-border">
            {recentOrders.map((order) => (
              <div class="flex items-center justify-between px-4 py-3 text-sm">
                <div class="flex items-center gap-3">
                  <span class="text-xs text-text-muted font-mono">#{order.id}</span>
                  <span class={`text-xs font-medium ${statusColors[order.status] ?? 'text-text-muted'}`}>
                    {statusLabels[order.status] ?? order.status}
                  </span>
                </div>
                <div class="flex items-center gap-4">
                  <span class="text-xs text-text-muted">{new Date(order.created_at).toLocaleDateString('es-ES')}</span>
                  <span class="font-medium">{formatPrice(order.total)}</span>
                </div>
              </div>
            ))}
          </div>
        </div>
      )
    }

    <div class="mt-6 flex flex-wrap gap-3">
      {isAdmin && (
        <a
          href="/admin"
          class="inline-flex items-center gap-2 rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90 transition-colors"
        >
          Panel de administración
        </a>
      )}
      <form method="POST" action="/api/auth/signout">
        <button
          type="submit"
          class="cursor-pointer rounded-lg border border-border px-4 py-2 text-sm text-text-muted hover:text-text-primary hover:border-border-hover transition-colors"
        >
          Cerrar sesión
        </button>
      </form>
    </div>
  </div>
</StoreLayout>
