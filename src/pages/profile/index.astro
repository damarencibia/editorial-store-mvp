---
import StoreLayout from '../../layouts/StoreLayout.astro'
import ProfileForm from '../../components/store/ProfileForm.vue'
import DeleteAccountModal from '../../components/store/DeleteAccountModal.vue'
import { getServerSupabase } from '../../lib/auth'
import { getServerProfile } from '../../lib/profiles'

const supabase = getServerSupabase(Astro.request, (name, value, options) => {
  Astro.cookies.set(name, value, options as any)
})
const { data: { user } } = await supabase.auth.getUser()

if (!user) {
  return Astro.redirect('/auth/login')
}

const profile = await getServerProfile(supabase)
const isAdmin = profile?.role === 'admin'

const { data: orders } = await supabase
  .from('orders')
  .select('*')
  .eq('user_id', user.id)
  .order('created_at', { ascending: false })

const { data: userReviews } = await supabase
  .from('reviews')
  .select('*, books!inner(title, slug, cover_url)')
  .eq('user_id', user.id)
  .order('created_at', { ascending: false })

function formatPrice(cents: number): string {
  return '$' + (cents / 100).toFixed(2)
}

function formatDate(date: string): string {
  return new Date(date).toLocaleDateString('es-ES', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  })
}

const statusColors: Record<string, string> = {
  pending: 'text-yellow-400 bg-yellow-400/10',
  paid: 'text-green-400 bg-green-400/10',
  shipped: 'text-blue-400 bg-blue-400/10',
  cancelled: 'text-red-400 bg-red-400/10',
}

const statusLabels: Record<string, string> = {
  pending: 'Pendiente',
  paid: 'Pagado',
  shipped: 'Enviado',
  cancelled: 'Cancelado',
}

const initials = profile?.full_name
  ? profile.full_name.split(' ').map((n: string) => n[0]).join('').toUpperCase().slice(0, 2)
  : (user.email?.charAt(0).toUpperCase() || '?')

const memberSince = profile?.created_at
  ? new Date(profile.created_at).toLocaleDateString('es-ES', { year: 'numeric', month: 'long' })
  : null
---

<StoreLayout>
  <title>Mi perfil — Arraigo Editorial</title>

  <div class="max-w-3xl mx-auto">

    <!-- Profile header -->
    <div class="relative rounded-xl border border-border bg-surface-2 p-6 sm:p-8 animate-in">
      <div class="absolute top-3 right-3 sm:top-5 sm:right-5 flex items-start gap-2">
        {isAdmin && (
          <a
            href="/admin"
            class="inline-flex items-center gap-1.5 rounded-lg px-3 py-1.5 text-xs font-medium text-amber-400 bg-amber-400/5 ring-2 ring-amber-400 shadow-[0_0_10px_rgba(251,191,36,0.5)] hover:bg-amber-400/10 transition-colors"
          >
            <svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="currentColor">
              <path d="M22.7,19L13.6,9.9C14.5,7.6 14,4.9 12.1,3C10.1,1 7.1,0.6 4.7,1.7L9,6L6,9L1.6,4.7C0.4,7.1 0.9,10.1 2.9,12.1C4.8,14 7.5,14.5 9.8,13.6L19,22.7C19.4,23.1 19.8,23.1 20.2,22.7L22.7,20.2C23.1,19.8 23.1,19.4 22.7,19Z" />
            </svg>
            Admin
          </a>
        )}
        <form method="POST" action="/api/auth/signout">
          <button
            type="submit"
            class="cursor-pointer rounded-lg border border-border px-3 py-1.5 text-xs text-text-muted hover:text-text-primary hover:border-border-hover transition-colors"
          >
            Cerrar sesión
          </button>
        </form>
      </div>

      <div class="flex flex-col sm:flex-row items-center sm:items-start gap-5 sm:gap-6">
        <div
          class="flex h-16 w-16 sm:h-20 sm:w-20 items-center justify-center rounded-full font-heading text-xl sm:text-2xl font-bold text-white shrink-0"
          style="background: linear-gradient(135deg, #F92672, #AE81FF);"
        >
          {initials}
        </div>
        <div class="flex-1 text-center sm:text-left">
          <div class="flex items-center justify-center sm:justify-start gap-3 flex-wrap">
            <h1 class="font-heading text-xl sm:text-2xl font-bold tracking-tight">
              {profile?.full_name || 'Usuario'}
            </h1>
          </div>
          <p class="text-sm text-text-muted mt-1">{user.email}</p>
          {memberSince && (
            <p class="text-xs text-text-dim mt-2">Miembro desde {memberSince}</p>
          )}
        </div>
      </div>

      <!-- Stats row -->
      <div class="grid grid-cols-3 gap-3 mt-6 pt-6 border-t border-border">
        <div class="text-center">
          <p class="font-heading text-xl font-bold">{orders?.length ?? 0}</p>
          <p class="text-xs text-text-muted mt-0.5">Pedidos</p>
        </div>
        <div class="text-center">
          <p class="font-heading text-xl font-bold">{userReviews?.length ?? 0}</p>
          <p class="text-xs text-text-muted mt-0.5">Reseñas</p>
        </div>
        <div class="text-center">
          <p class="font-heading text-xl font-bold">
            {orders && orders.length > 0
              ? formatPrice(orders.reduce((s: number, o: any) => s + o.total, 0))
              : '$0'}
          </p>
          <p class="text-xs text-text-muted mt-0.5">Gastado</p>
        </div>
      </div>
    </div>

    <!-- Orders section -->
    <div class="mt-8 animate-in">
      <div class="flex items-center justify-between mb-5">
        <h2 class="font-heading text-lg font-semibold">Mis pedidos</h2>
        {orders && orders.length > 5 && (
          <a href="/orders" class="text-xs text-accent hover:text-accent/80 transition-colors">Ver todos &rarr;</a>
        )}
      </div>

      {orders && orders.length > 0 ? (
        <div class="space-y-3">
          {orders.slice(0, 5).map((order) => {
            const statusColor = statusColors[order.status] ?? 'text-text-muted bg-surface-2'
            const statusLabel = statusLabels[order.status] ?? order.status
            return (
              <div class="rounded-lg border border-border bg-surface-2 overflow-hidden">
                <div class="flex items-center justify-between px-4 sm:px-5 py-3 border-b border-border bg-surface-2/60">
                  <div class="flex items-center gap-3">
                    <span class="text-xs text-text-muted font-mono">#{order.id}</span>
                    <span class={`inline-block rounded-full px-2.5 py-0.5 text-xs font-medium ${statusColor}`}>
                      {statusLabel}
                    </span>
                  </div>
                  <span class="text-xs text-text-muted">{formatDate(order.created_at)}</span>
                </div>

                <div class="px-4 sm:px-5 py-3 space-y-2">
                  {order.items.slice(0, 3).map((item: any) => (
                    <a
                      href={`/book/${item.slug}`}
                      class="flex items-center gap-3 text-sm group"
                    >
                      {item.coverUrl && (
                        <img src={item.coverUrl} alt={item.title} class="w-8 h-11 object-cover rounded flex-shrink-0" />
                      )}
                      <div class="flex-1 min-w-0">
                        <p class="text-text-primary font-medium truncate group-hover:text-accent transition-colors">{item.title}</p>
                        <p class="text-text-muted text-xs">{item.author}</p>
                      </div>
                      <div class="text-right shrink-0">
                        <p class="text-text-primary font-medium text-xs">{item.quantity} &times; {formatPrice(item.price)}</p>
                        <p class="text-text-muted text-[11px]">{formatPrice(item.price * item.quantity)}</p>
                      </div>
                    </a>
                  ))}
                  {order.items.length > 3 && (
                    <p class="text-xs text-text-dim text-center pt-1">+{order.items.length - 3} artículo{order.items.length - 3 !== 1 ? 's' : ''} más</p>
                  )}
                </div>

                <div class="flex items-center justify-between px-4 sm:px-5 py-2.5 border-t border-border bg-surface-2/40">
                  <span class="text-xs text-text-muted">{order.items.length} artículo{order.items.length !== 1 ? 's' : ''}</span>
                  <span class="font-heading font-semibold text-sm">{formatPrice(order.total)}</span>
                </div>
              </div>
            )
          })}
        </div>
      ) : (
        <div class="rounded-lg border border-border bg-surface-2 p-8 text-center">
          <p class="text-sm text-text-muted">No tienes pedidos aún.</p>
          <a
            href="/"
            class="inline-flex items-center gap-2 rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90 transition-colors mt-4"
          >
            Ir a la tienda
          </a>
        </div>
      )}
    </div>

    <!-- Reviews section -->
    <div class="mt-8 animate-in">
      <h2 class="font-heading text-lg font-semibold mb-5">Mis reseñas</h2>

      {userReviews && userReviews.length > 0 ? (
        <div class="space-y-3">
          {userReviews.map((review: any) => {
            const bookTitle = review.books?.title || 'Libro'
            const bookSlug = review.books?.slug || ''
            const bookCover = review.books?.cover_url || ''

            function starDisplay(rating: number): string {
              return Array.from({ length: 5 }, (_, i) =>
                `<svg width="14" height="14" viewBox="0 0 24 24" fill="${i < rating ? '#fbbf24' : 'none'}" stroke="#fbbf24" stroke-width="1.5" style="display:inline;vertical-align:middle"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`
              ).join('')
            }

            return (
              <div class="rounded-lg border border-border bg-surface-2 p-4">
                <div class="flex items-start gap-3">
                  {bookCover && (
                    <a href={`/book/${bookSlug}`} class="shrink-0">
                      <img src={bookCover} alt={bookTitle} class="w-10 h-14 object-cover rounded" />
                    </a>
                  )}
                  <div class="flex-1 min-w-0">
                    <a href={`/book/${bookSlug}`} class="text-sm font-medium text-text-primary hover:text-accent transition-colors">
                      {bookTitle}
                    </a>
                    <div class="flex items-center gap-2 mt-0.5" set:html={starDisplay(review.rating)} />
                    <p class="text-sm text-text-primary mt-2 leading-relaxed whitespace-pre-wrap">{review.comment}</p>
                    <div class="flex items-center gap-2 mt-2">
                      <span class="text-xs text-text-dim">{formatDate(review.created_at)}</span>
                      {review.is_edited && <span class="text-[11px] text-text-dim italic">(editada)</span>}
                    </div>
                  </div>
                </div>
              </div>
            )
          })}
        </div>
      ) : (
        <div class="rounded-lg border border-border bg-surface-2 p-8 text-center">
          <p class="text-sm text-text-muted">No has escrito ninguna reseña aún.</p>
          <a
            href="/books"
            class="inline-flex items-center gap-2 rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90 transition-colors mt-4"
          >
            Explorar libros
          </a>
        </div>
      )}
    </div>

    <!-- Profile form section -->
    <div class="mt-8 animate-in">
      <ProfileForm client:only="vue" />
    </div>

    <!-- Delete account section (hidden for admins) -->
    {!isAdmin && (
      <div class="mt-10 pt-8 border-t border-border animate-in">
        <DeleteAccountModal fullName={profile?.full_name || ''} client:only="vue" />
      </div>
    )}

  </div>
</StoreLayout>
