---
import StoreLayout from '../layouts/StoreLayout.astro'
import BookCard from '../components/store/BookCard.vue'
import TopPicksCarousel from '../components/store/TopPicksCarousel.vue'
import { supabase } from '../lib/supabase'

let error: string | null = null
let collections: any[] = []
let trending: any[] = []
let topPicks: any[] = []
try {
  const { data: colData, error: colErr } = await supabase
    .from('collections')
    .select('*, categories(count)')
    .order('name')
  if (colErr) throw new Error('Error al cargar colecciones')
  collections = colData ?? []

  const { data: trendingData } = await supabase
    .from('books')
    .select('*, authors!left(name), categories(name, slug)')
    .eq('is_visible', true)
    .eq('is_trending', true)
    .order('sales_count', { ascending: false })
    .limit(9)
  trending = (trendingData ?? []).map((b: any) => ({
    ...b,
    author: b.authors?.name ?? 'Autor desconocido',
  }))

  const { data: picksData } = await supabase
    .from('monthly_picks')
    .select('position, books(*)')
    .order('position')
  topPicks = (picksData ?? []).map(p => p.books).filter(Boolean)
} catch (e) {
  error = e instanceof Error ? e.message : 'Error al cargar el contenido'
}
---

<StoreLayout>
  <title>Arraigo Editorial — Palabras que echan raíces</title>
  <meta property="og:title" slot="head" content="Arraigo Editorial — Palabras que echan raíces" />
  <meta property="og:description" slot="head" content="Descubre nuestra colección curada de libros que cruzan la frontera entre la cultura clásica y el pensamiento contemporáneo." />
  <meta property="og:type" slot="head" content="website" />

  <div slot="hero">
    <section class="relative mb-16 sm:mb-24 overflow-hidden border-b border-border h-[100dvh] sm:h-auto flex flex-col sm:block">
      <div class="absolute inset-0">
        <img src="/images/hero-bg.jpg" alt="" class="h-full w-full object-cover" />
        <div class="absolute inset-0 bg-gradient-to-r from-surface-1 via-surface-1/60 to-surface-1/20" />
      </div>
      <div class="relative z-10 px-4 sm:px-6 lg:px-8 pt-16 sm:py-20 lg:py-24 flex-1 flex flex-col sm:block" style="max-width: 1280px; margin: 0 auto;">
      <div class="max-w-2xl flex flex-col h-full sm:block">
        <div class="sm:block">
          <p class="text-xs font-semibold uppercase tracking-widest text-accent mb-4">
            Arraigo Editorial
          </p>
          <h1 class="font-heading text-5xl lg:text-6xl font-bold tracking-tight leading-tight">
            Palabras que
            <span class="text-accent">echan raíces</span>
          </h1>
          <p class="mt-5 text-lg text-text-muted leading-relaxed max-w-lg">
            Historias que transforman, conocimiento que perdura. Donde cada página es una semilla.
          </p>
        </div>
        <div class="flex-1 sm:hidden"></div>
        <div class="sm:mt-8 pb-8 sm:pb-0 mb-16 sm:mb-0 flex flex-wrap gap-3">
          <a
            href="#colecciones"
            class="inline-flex items-center gap-2 rounded-lg bg-accent px-6 py-3 text-sm font-medium text-white hover:bg-accent/90 transition-all duration-200"
          >
            Explorar colecciones
            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="5" y1="12" x2="19" y2="12" />
              <polyline points="12 5 19 12 12 19" />
            </svg>
          </a>
          <a
            href="#colecciones"
            class="inline-flex items-center gap-2 rounded-lg border border-border px-6 py-3 text-sm font-medium text-text-muted hover:text-text-primary hover:border-border-hover transition-all duration-200"
          >
            Ver todas
          </a>
        </div>
      </div>
    </div>
  </section>
  </div>

  {error && (
    <div class="rounded-lg border border-red-500/20 bg-red-500/5 px-5 py-4 text-sm text-red-400 mb-8">
      {error}
    </div>
  )}

  {topPicks.length > 0 && (
    <section class="mb-16">
      <div class="mb-6">
        <h2 class="font-heading text-2xl font-semibold">Top 10 del mes</h2>
        <p class="mt-1 text-text-muted">Nuestra selección imperdible de este mes.</p>
      </div>
      <TopPicksCarousel books={topPicks} client:only="vue" />
    </section>
  )}

  {trending.length > 0 && (
    <section class="mb-16">
      <div class="flex items-center justify-between mb-6">
        <h2 class="font-heading text-2xl font-semibold">Trending</h2>
        {trending.length > 8 && (
          <a href="/tendencias" class="text-sm text-accent hover:text-accent/80 transition-colors">
            Ver todos &rarr;
          </a>
        )}
      </div>
      <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 2xl:grid-cols-7 gap-3 sm:gap-4">
        {trending.slice(0, 8).map((book) => (
          <BookCard book={book} client:only="vue" />
        ))}
      </div>
    </section>
  )}

  <section id="colecciones" class="mb-16">
    <div class="mb-8">
      <h2 class="font-heading text-2xl font-semibold">Colecciones</h2>
      <p class="mt-1 text-text-muted">Explora nuestras colecciones curadas de libros.</p>
    </div>

    {collections.length === 0 && !error && (
      <p class="text-center py-16 text-text-muted">No hay colecciones disponibles.</p>
    )}

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {collections.map((col: any) => {
        const count = col.categories?.[0]?.count ?? 0
        return (
          <a
            href={`/colecciones/${col.slug}`}
            class="group block rounded-xl border border-border bg-surface-2 overflow-hidden hover:border-accent/40 transition-all duration-200"
          >
            {col.cover_url && (
              <div class="aspect-[3/1] overflow-hidden">
                <img
                  src={col.cover_url}
                  alt={col.name}
                  class="h-full w-full object-cover group-hover:scale-105 transition-transform duration-300"
                />
              </div>
            )}
            <div class={col.cover_url ? 'p-4' : 'p-5'}>
              <h3 class="font-heading text-lg font-semibold text-text-primary group-hover:text-accent transition-colors">
                {col.name}
              </h3>
              {col.description && (
                <p class="mt-1 text-sm text-text-muted line-clamp-2">{col.description}</p>
              )}
              <p class="mt-3 text-xs text-text-dim">{count} {count === 1 ? 'categoría' : 'categorías'}</p>
            </div>
          </a>
        )
      })}
    </div>
  </section>
</StoreLayout>
