---
import StoreLayout from '../layouts/StoreLayout.astro'
---

<StoreLayout>
  <title>Pago exitoso — Editorial</title>
  <div class="flex flex-col items-center justify-center py-20 text-center">
    <div class="mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-green-500/10">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-green-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="20 6 9 17 4 12" />
      </svg>
    </div>
    <h1 class="font-heading text-3xl font-bold tracking-tight mb-2">Payment Successful!</h1>
    <p class="text-text-muted mb-8 max-w-md">
      Thank you for your purchase. Your order has been placed and you'll receive a confirmation shortly.
    </p>
    <a
      href="/"
      class="rounded-lg bg-accent px-6 py-2.5 text-sm font-medium text-white hover:bg-accent/90 transition-colors"
    >
      Continue Shopping
    </a>
  </div>
</StoreLayout>
