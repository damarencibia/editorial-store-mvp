---
import StoreLayout from '../../layouts/StoreLayout.astro'
import BookCard from '../../components/store/BookCard.vue'
import { supabase } from '../../lib/supabase'

const { data: collections } = await supabase
  .from('collections')
  .select('*, categories(count)')
  .order('name')

const { data: trending } = await supabase
  .from('books')
  .select('*, categories(name, slug)')
  .eq('is_visible', true)
  .eq('is_trending', true)
  .order('sales_count', { ascending: false })
  .limit(8)
---

<StoreLayout>
  <title>Colecciones — Arraigo Editorial</title>

  <section>
    <div class="mb-10">
      <h1 class="font-heading text-3xl sm:text-4xl font-bold tracking-tight">Colecciones</h1>
      <p class="mt-2 text-text-muted">Explora nuestras colecciones curadas de libros.</p>
    </div>

    {trending && trending.length > 0 && (
      <section class="mb-12">
        <h2 class="font-heading text-xl font-semibold mb-4">Tendencias</h2>
        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4 sm:gap-6">
          {trending.map((book) => (
            <BookCard book={book} client:only="vue" />
          ))}
        </div>
      </section>
    )}

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {(collections ?? []).length === 0 && (
        <p class="col-span-full text-center py-16 text-text-muted">
          No hay colecciones disponibles.
        </p>
      )}

      {(collections ?? []).map((col: any) => {
        const count = col.categories?.[0]?.count ?? 0
        return (
          <a
            href={`/colecciones/${col.slug}`}
            class="group block rounded-xl border border-border bg-surface-2 overflow-hidden hover:border-accent/40 transition-all duration-200"
          >
            {col.cover_url && (
              <div class="aspect-[3/1] overflow-hidden">
                <img
                  src={col.cover_url}
                  alt={col.name}
                  class="h-full w-full object-cover group-hover:scale-105 transition-transform duration-300"
                />
              </div>
            )}
            <div class={col.cover_url ? 'p-4' : 'p-5'}>
              <h2 class="font-heading text-lg font-semibold text-text-primary group-hover:text-accent transition-colors">
                {col.name}
              </h2>
              {col.description && (
                <p class="mt-1 text-sm text-text-muted line-clamp-2">{col.description}</p>
              )}
              <p class="mt-3 text-xs text-text-dim">{count} {count === 1 ? 'categoría' : 'categorías'}</p>
            </div>
          </a>
        )
      })}
    </div>
  </section>
</StoreLayout>
