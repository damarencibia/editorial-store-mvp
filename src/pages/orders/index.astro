---
import StoreLayout from '../../layouts/StoreLayout.astro'
import { getServerSupabase } from '../../lib/auth'

const supabase = getServerSupabase(Astro.request, (name, value, options) => {
  Astro.cookies.set(name, value, options as any)
})
const { data: { user } } = await supabase.auth.getUser()

if (!user) {
  return Astro.redirect('/auth/login')
}

const { data: orders } = await supabase
  .from('orders')
  .select('*')
  .eq('user_id', user.id)
  .order('created_at', { ascending: false })

function formatPrice(cents: number): string {
  return '$' + (cents / 100).toFixed(2)
}

function formatDate(date: string): string {
  return new Date(date).toLocaleDateString('es-ES', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  })
}

const statusColors: Record<string, string> = {
  pending: 'text-yellow-400 bg-yellow-400/10',
  paid: 'text-green-400 bg-green-400/10',
  shipped: 'text-blue-400 bg-blue-400/10',
  cancelled: 'text-red-400 bg-red-400/10',
}

const statusLabels: Record<string, string> = {
  pending: 'Pendiente',
  paid: 'Pagado',
  shipped: 'Enviado',
  cancelled: 'Cancelado',
}
---

<StoreLayout>
  <title>Mis pedidos — Arraigo Editorial</title>

  <div class="max-w-3xl mx-auto">
    <h1 class="font-heading text-2xl font-bold tracking-tight mb-8">Mis pedidos</h1>

    {
      orders && orders.length > 0 ? (
        <div class="space-y-4">
          {orders.map((order) => {
            const statusColor = statusColors[order.status] ?? 'text-text-muted bg-surface-2'
            const statusLabel = statusLabels[order.status] ?? order.status
            return (
              <div class="rounded-lg border border-border bg-surface-2 overflow-hidden">
                <div class="flex items-center justify-between px-5 py-4 border-b border-border bg-surface-2/60">
                  <div class="flex items-center gap-3">
                    <span class="text-xs text-text-muted font-mono">#{order.id}</span>
                    <span class={`inline-block rounded-full px-2.5 py-0.5 text-xs font-medium ${statusColor}`}>
                      {statusLabel}
                    </span>
                  </div>
                  <span class="text-xs text-text-muted">{formatDate(order.created_at)}</span>
                </div>

                <div class="px-5 py-4 space-y-3">
                  <div class="space-y-1.5">
                    {order.items.map((item: any) => (
                      <div class="flex items-center gap-3 text-sm">
                        {
                          item.coverUrl && (
                            <img src={item.coverUrl} alt={item.title} class="w-8 h-11 object-cover rounded flex-shrink-0" />
                          )
                        }
                        <div class="flex-1 min-w-0">
                          <p class="text-text-primary font-medium truncate">{item.title}</p>
                          <p class="text-text-muted text-xs">{item.author} &middot; Qty: {item.quantity}</p>
                        </div>
                        <p class="text-text-primary font-medium">{formatPrice(item.price * item.quantity)}</p>
                      </div>
                    ))}
                  </div>

                  <div class="border-t border-border pt-3 space-y-1 text-xs text-text-muted">
                    {order.shipping_name && <p><span class="font-medium text-text-primary">Envío a:</span> {order.shipping_name}</p>}
                    {order.shipping_address?.line1 && (
                      <p>
                        {order.shipping_address.line1}
                        {order.shipping_address.line2 ? `, ${order.shipping_address.line2}` : ''}
                        &nbsp;&middot; {order.shipping_address.city}, {order.shipping_address.state} {order.shipping_address.postal_code}
                      </p>
                    )}
                  </div>
                </div>

                <div class="flex items-center justify-between px-5 py-3 border-t border-border bg-surface-2/40">
                  <span class="text-xs text-text-muted">{order.items.length} artículo{order.items.length !== 1 ? 's' : ''}</span>
                  <span class="font-heading font-semibold text-base">{formatPrice(order.total)}</span>
                </div>
              </div>
            )
          })}
        </div>
      ) : (
        <div class="text-center py-16">
          <p class="text-text-muted mb-4">No tienes pedidos aún.</p>
          <a
            href="/"
            class="inline-flex items-center gap-2 rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90 transition-colors"
          >
            Ir a la tienda
          </a>
        </div>
      )
    }
  </div>
</StoreLayout>
