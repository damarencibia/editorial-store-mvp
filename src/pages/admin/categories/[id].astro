---
import AdminLayout from '../../../layouts/AdminLayout.astro'
import CategoryForm from '../../../components/admin/CategoryForm.vue'
import { getServerSupabase } from '../../../lib/auth'
import { getServerProfile } from '../../../lib/profiles'

const supabase = getServerSupabase(Astro.request, (name, value, options) => {
  Astro.cookies.set(name, value, options as any)
})
const profile = await getServerProfile(supabase)
if (!profile || profile.role !== 'admin') return Astro.redirect('/')

const { id } = Astro.params
const categoryId = Number(id)
const { data: category } = await supabase.from('categories').select('*').eq('id', categoryId).single()

if (!category) {
  return Astro.redirect('/admin/categories')
}
---

<AdminLayout>
  <title>Editar categoría — Admin</title>

  <div class="max-w-xl">
    <div class="flex items-center gap-3 mb-6">
      <a href="/admin/categories" class="text-text-muted hover:text-text-primary transition-colors">&larr;</a>
      <h1 class="font-heading text-2xl font-bold tracking-tight">Editar categoría</h1>
    </div>
    <CategoryForm client:load />
    <script id="category-data" type="application/json" set:html={JSON.stringify({
      id: category.id,
      name: category.name,
      slug: category.slug,
    })}></script>
  </div>
</AdminLayout>
