---
import AdminLayout from '../../../layouts/AdminLayout.astro'
import DataTable from '../../../components/admin/DataTable.vue'
import { getServerSupabase } from '../../../lib/auth'
import { getServerProfile } from '../../../lib/profiles'

const supabase = getServerSupabase(Astro.request, (name, value, options) => {
  Astro.cookies.set(name, value, options as any)
})
const profile = await getServerProfile(supabase)
if (!profile || profile.role !== 'admin') return Astro.redirect('/')

const { data: categories } = await supabase.from('categories').select('*').order('name')

const columns = [
  { key: 'name', label: 'Nombre' },
  { key: 'slug', label: 'Slug' },
  { key: 'created_at', label: 'Creado' },
]

const actions = [
  { label: 'Editar', href: '/admin/categories/{id}' },
]
---
<AdminLayout>
  <title>Categorías — Admin</title>

  <div class="max-w-3xl">
    <div class="flex items-center justify-between mb-6">
      <h1 class="font-heading text-2xl font-bold tracking-tight">Categorías</h1>
      <a
        href="/admin/categories/new"
        class="rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90 transition-colors"
      >
        + Nueva categoría
      </a>
    </div>

    <DataTable
      client:load
      emptyText="No hay categorías registradas."
    />
    <script id="books-data" type="application/json" set:html={JSON.stringify({ columns, rows: categories ?? [], actions })}></script>
  </div>
</AdminLayout>
