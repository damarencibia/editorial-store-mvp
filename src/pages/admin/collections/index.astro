---
import AdminLayout from '../../../layouts/AdminLayout.astro'
import { getServerSupabase } from '../../../lib/auth'
import { getServerProfile } from '../../../lib/profiles'

const supabase = getServerSupabase(Astro.request, (name, value, options) => {
  Astro.cookies.set(name, value, options as any)
})
const profile = await getServerProfile(supabase)
if (!profile || profile.role !== 'admin') return Astro.redirect('/')

const { data: collections } = await supabase
  .from('collections')
  .select('*, categories(count)')
  .order('name')

const mapped = (collections ?? []).map((c: any) => ({
  id: c.id,
  name: c.name,
  slug: c.slug,
  description: c.description,
  cover_url: c.cover_url,
  categories_count: c.categories?.[0]?.count ?? 0,
}))
---

<AdminLayout>
  <title>Colecciones — Admin</title>

  <div class="max-w-5xl">
    <div class="flex items-center justify-between mb-6">
      <h1 class="font-heading text-2xl font-bold tracking-tight">Colecciones</h1>
      <a
        href="/admin/collections/new"
        class="rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90 transition-colors"
      >
        + Nueva colección
      </a>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {mapped.length === 0 && (
        <div class="col-span-full py-16 text-center text-text-muted">
          <p>No hay colecciones registradas.</p>
          <a href="/admin/collections/new" class="mt-2 inline-block text-sm text-accent hover:text-accent/80 transition-colors">
            Crear primera colección
          </a>
        </div>
      )}

      {mapped.map((col) => (
        <a
          href={`/admin/collections/${col.id}`}
          class="group block rounded-xl border border-border bg-surface-2 overflow-hidden hover:border-accent/40 hover:bg-surface-2/80 transition-all duration-200"
        >
          {col.cover_url && (
            <div class="aspect-[3/1] overflow-hidden">
              <img
                src={col.cover_url}
                alt={col.name}
                class="h-full w-full object-cover group-hover:scale-105 transition-transform duration-300"
              />
            </div>
          )}
          <div class={col.cover_url ? 'p-4' : 'p-5'}>
            <h2 class="font-heading text-lg font-semibold text-text-primary group-hover:text-accent transition-colors">
              {col.name}
            </h2>
            {col.description && (
              <p class="mt-1 text-sm text-text-muted line-clamp-2">{col.description}</p>
            )}
            <p class="mt-3 text-xs text-text-dim">
              {col.categories_count} {col.categories_count === 1 ? 'categoría' : 'categorías'}
            </p>
          </div>
        </a>
      ))}
    </div>
  </div>
</AdminLayout>
