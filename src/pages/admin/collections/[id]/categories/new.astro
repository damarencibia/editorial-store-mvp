---
import AdminLayout from '../../../../../layouts/AdminLayout.astro'
import CategoryForm from '../../../../../components/admin/CategoryForm.vue'
import { getServerSupabase } from '../../../../../lib/auth'
import { getServerProfile } from '../../../../../lib/profiles'

const supabase = getServerSupabase(Astro.request, (name, value, options) => {
  Astro.cookies.set(name, value, options as any)
})
const profile = await getServerProfile(supabase)
if (!profile || profile.role !== 'admin') return Astro.redirect('/')

const { id } = Astro.params
const collectionId = Number(id)
const { data: collection } = await supabase
  .from('collections')
  .select('name')
  .eq('id', collectionId)
  .single()

if (!collection) {
  return Astro.redirect('/admin/collections')
}
---

<AdminLayout>
  <title>Nueva categoría — Admin</title>

  <div class="max-w-xl">
    <div class="flex items-center gap-3 mb-6">
      <a href={`/admin/collections/${collectionId}`} class="text-text-muted hover:text-text-primary transition-colors">&larr;</a>
      <h1 class="font-heading text-2xl font-bold tracking-tight">
        Nueva categoría en <span class="text-accent">{collection.name}</span>
      </h1>
    </div>
    <CategoryForm client:only="vue" />
    <script id="collection-data" type="application/json" set:html={JSON.stringify({
      id: collectionId,
    })}></script>
  </div>
</AdminLayout>
