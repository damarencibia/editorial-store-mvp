---
import AdminLayout from '../../../layouts/AdminLayout.astro'
import CollectionForm from '../../../components/admin/CollectionForm.vue'
import { getServerSupabase } from '../../../lib/auth'
import { getServerProfile } from '../../../lib/profiles'

const supabase = getServerSupabase(Astro.request, (name, value, options) => {
  Astro.cookies.set(name, value, options as any)
})
const profile = await getServerProfile(supabase)
if (!profile || profile.role !== 'admin') return Astro.redirect('/')

const { id } = Astro.params
const collectionId = Number(id)
const { data: collection } = await supabase
  .from('collections')
  .select('*')
  .eq('id', collectionId)
  .single()

if (!collection) {
  return Astro.redirect('/admin/collections')
}

const { data: categories } = await supabase
  .from('categories')
  .select('*')
  .eq('collection_id', collectionId)
  .order('name')
---

<AdminLayout>
  <title>{collection.name} — Admin</title>

  <div class="max-w-4xl">
    <div class="flex items-center gap-3 mb-6">
      <a href="/admin/collections" class="text-text-muted hover:text-text-primary transition-colors">&larr;</a>
      <h1 class="font-heading text-2xl font-bold tracking-tight">{collection.name}</h1>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <!-- Collection form -->
      <div>
        <h2 class="font-heading text-lg font-semibold mb-4">Editar colección</h2>
        <CollectionForm client:load />
        <script id="collection-data" type="application/json" set:html={JSON.stringify({
          id: collection.id,
          name: collection.name,
          slug: collection.slug,
          description: collection.description ?? '',
          cover_url: collection.cover_url ?? '',
        })}></script>
      </div>

      <!-- Categories list -->
      <div>
        <div class="flex items-center justify-between mb-4">
          <h2 class="font-heading text-lg font-semibold">Categorías</h2>
          <a
            href={`/admin/collections/${collection.id}/categories/new`}
            class="rounded-lg bg-accent px-3 py-1.5 text-xs font-medium text-white hover:bg-accent/90 transition-colors"
          >
            + Nueva
          </a>
        </div>

        <div class="space-y-2">
          {(categories ?? []).length === 0 && (
            <p class="py-8 text-center text-sm text-text-muted">
              No hay categorías en esta colección.
            </p>
          )}

          {(categories ?? []).map((cat) => (
            <div class="flex items-center justify-between rounded-lg border border-border bg-surface-2 px-4 py-3">
              <div>
                <p class="text-sm font-medium text-text-primary">{cat.name}</p>
                <p class="text-xs text-text-muted">/{cat.slug}</p>
              </div>
              <div class="flex items-center gap-2">
                <a
                  href={`/admin/collections/${collection.id}/categories/${cat.id}`}
                  class="rounded-md px-2.5 py-1 text-xs text-text-muted hover:text-text-primary hover:bg-surface-3 transition-colors"
                >
                  Editar
                </a>
                <form
                  method="POST"
                  action={`/api/admin/categories/${cat.id}?_method=DELETE&collection_id=${collection.id}`}
                  onsubmit="return confirm('¿Eliminar esta categoría?')"
                >
                  <button
                    type="submit"
                    class="cursor-pointer rounded-md px-2.5 py-1 text-xs text-red-400 hover:bg-red-500/10 transition-colors"
                  >
                    Eliminar
                  </button>
                </form>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</AdminLayout>
