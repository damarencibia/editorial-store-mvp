---
import AdminLayout from '../../../layouts/AdminLayout.astro'
import { getServerSupabase } from '../../../lib/auth'
import { getServerProfile } from '../../../lib/profiles'

const supabase = getServerSupabase(Astro.request, (name, value, options) => {
  Astro.cookies.set(name, value, options as any)
})
const profile = await getServerProfile(supabase)
if (!profile || profile.role !== 'admin') return Astro.redirect('/')

const { id } = Astro.params
const seriesId = Number(id)
const { data: series } = await supabase
  .from('series')
  .select('*')
  .eq('id', seriesId)
  .single()

if (!series) {
  return Astro.redirect('/admin/series')
}

const { data: books } = await supabase
  .from('books')
  .select('id, title')
  .eq('series_id', seriesId)
  .order('title')
---

<AdminLayout>
  <title>{series.name} — Admin</title>

  <div class="max-w-xl">
    <div class="flex items-center gap-3 mb-6">
      <a href="/admin/series" class="text-text-muted hover:text-text-primary transition-colors">&larr;</a>
      <h1 class="font-heading text-2xl font-bold tracking-tight">{series.name}</h1>
    </div>

    <form id="series-form" class="space-y-4">
      <div>
        <label for="name" class="block text-xs font-medium text-text-muted mb-1.5">Nombre</label>
        <input
          id="name"
          name="name"
          value={series.name}
          required
          class="w-full rounded-lg border border-border bg-surface-2 px-4 py-2.5 text-sm text-text-primary placeholder-text-dim transition-colors focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent/30"
        />
        <p id="error" class="hidden mt-2 text-sm text-red-400"></p>
      </div>

      <div class="flex items-center gap-3 pt-2">
        <button
          type="submit"
          id="save-btn"
          class="cursor-pointer rounded-lg bg-accent px-5 py-2.5 text-sm font-medium text-white hover:bg-accent/90 disabled:opacity-50 transition-colors"
        >
          Guardar cambios
        </button>
        <a href="/admin/series" class="text-sm text-text-muted hover:text-text-primary transition-colors">
          Cancelar
        </a>
        <button
          type="button"
          id="delete-btn"
          class="cursor-pointer ml-auto rounded-lg border border-red-500/20 px-3 py-1.5 text-xs font-medium text-red-400 hover:bg-red-500/5 transition-colors"
        >
          Eliminar serie
        </button>
      </div>
    </form>

    <div class="mt-10">
      <h2 class="font-heading text-lg font-semibold mb-3">Libros en esta serie</h2>
      {(books ?? []).length === 0 && (
        <p class="py-6 text-sm text-text-muted text-center">No hay libros en esta serie.</p>
      )}
      <ul class="space-y-1">
        {(books ?? []).map(b => (
          <li>
            <a href={`/admin/books/${b.id}`} class="text-sm text-text-muted hover:text-accent transition-colors">
              {b.title}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </div>
</AdminLayout>

<script>
const form = document.getElementById('series-form') as HTMLFormElement
const nameInput = document.getElementById('name') as HTMLInputElement
const errorEl = document.getElementById('error') as HTMLElement
const saveBtn = document.getElementById('save-btn') as HTMLButtonElement
const deleteBtn = document.getElementById('delete-btn') as HTMLButtonElement
const SERIES_ID = Number(window.location.pathname.split('/').pop())

form.addEventListener('submit', async (e) => {
  e.preventDefault()
  errorEl.classList.add('hidden')
  saveBtn.disabled = true
  saveBtn.textContent = 'Guardando...'

  try {
    const res = await fetch(`/api/admin/series/${SERIES_ID}`, {
      method: 'PUT',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ name: nameInput.value.trim() }),
    })
    if (!res.ok) {
      const data = await res.json()
      errorEl.textContent = data.error || 'Error al guardar'
      errorEl.classList.remove('hidden')
      return
    }
    window.location.reload()
  } catch {
    errorEl.textContent = 'Error interno'
    errorEl.classList.remove('hidden')
  } finally {
    saveBtn.disabled = false
    saveBtn.textContent = 'Guardar cambios'
  }
})

deleteBtn.addEventListener('click', async () => {
  if (!confirm('¿Eliminar esta serie?')) return

  try {
    const res = await fetch(`/api/admin/series/${SERIES_ID}`, { method: 'DELETE' })
    if (!res.ok) {
      const data = await res.json()
      alert(data.error || 'Error al eliminar')
      return
    }
    window.location.href = '/admin/series'
  } catch {
    alert('Error al eliminar')
  }
})
</script>
