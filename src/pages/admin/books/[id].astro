---
import AdminLayout from '../../../layouts/AdminLayout.astro'
import BookForm from '../../../components/admin/BookForm.vue'
import { getServerSupabase } from '../../../lib/auth'
import { getServerProfile } from '../../../lib/profiles'

const supabase = getServerSupabase(Astro.request, (name, value, options) => {
  Astro.cookies.set(name, value, options as any)
})
const profile = await getServerProfile(supabase)
if (!profile || profile.role !== 'admin') return Astro.redirect('/')

const { id } = Astro.params
const bookId = Number(id)
const { data: book } = await supabase.from('books').select('*, series(name)').eq('id', bookId).single()

if (!book) {
  return Astro.redirect('/admin/books')
}

const { data: collections } = await supabase.from('collections').select('id, name').order('name')
const { data: categories } = await supabase.from('categories').select('id, name, collection_id').order('name')
---

<AdminLayout>
  <title>Editar libro — Admin</title>

  <div class="max-w-2xl">
    <div class="flex items-center justify-between mb-6">
      <div class="flex items-center gap-3">
        <a href="/admin/books" class="text-text-muted hover:text-text-primary transition-colors">&larr;</a>
        <h1 class="font-heading text-2xl font-bold tracking-tight">Editar libro</h1>
      </div>
      <button
        id="delete-book-btn"
        data-book-id={bookId}
        class="cursor-pointer rounded-lg border border-red-500/20 px-3 py-1.5 text-xs font-medium text-red-400 hover:bg-red-500/5 transition-colors"
      >
        Eliminar libro
      </button>
    </div>
    <BookForm client:load />
  <script id="book-data" type="application/json" set:html={JSON.stringify({
    title: book.title,
    authorId: book.author_id,
    publisher: book.publisher ?? '',
    slug: book.slug,
    subtitle: book.subtitle ?? '',
    description: book.description ?? '',
    pages: String(book.pages ?? 0),
    translator: book.translator ?? '',
    seriesId: book.series_id ?? null,
    ageTarget: book.age_target ?? 'Todos',
    bindingType: book.binding_type ?? '',
    language: book.language ?? 'ES',
    publishedAt: book.published_at ?? '',
    price: String(book.price),
    coverUrl: book.cover_url ?? '',
    category_id: book.category_id,
    isVisible: book.is_visible ?? true,
    isBestSeller: book.is_best_seller ?? false,
    manualBestSeller: book.manual_best_seller ?? false,
  })}></script>
    <script id="collections-data" type="application/json" set:html={JSON.stringify(collections ?? [])}></script>
    <script id="categories-data" type="application/json" set:html={JSON.stringify(categories ?? [])}></script>
  </div>

  <div id="delete-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/60">
    <div class="max-w-md w-full mx-4 rounded-xl bg-surface-2 border border-border p-6 shadow-2xl">
      <h3 class="font-heading text-lg font-semibold mb-2">Eliminar libro</h3>
      <p class="text-sm text-text-muted mb-4">¿Eliminar este libro? Esta acción no se puede deshacer.</p>
      <label class="flex items-center gap-2 cursor-pointer select-none mb-6">
        <input type="checkbox" id="modal-delete-image" class="rounded border-border accent-accent" />
        <span class="text-xs text-text-muted">Eliminar también la imagen del almacenamiento</span>
      </label>
      <div class="flex items-center justify-end gap-3">
        <button id="cancel-delete" class="cursor-pointer rounded-lg px-4 py-2 text-sm text-text-muted hover:text-text-primary transition-colors">
          Cancelar
        </button>
        <button id="confirm-delete" class="cursor-pointer rounded-lg bg-red-500 px-4 py-2 text-sm font-medium text-white hover:bg-red-600 transition-colors">
          Eliminar
        </button>
      </div>
    </div>
  </div>

  <div id="loading-overlay" class="hidden fixed inset-0 z-[60] flex items-center justify-center bg-black/60">
    <div class="flex flex-col items-center gap-3">
      <div class="h-10 w-10 animate-spin rounded-full border-4 border-accent border-t-transparent"></div>
      <p class="text-sm font-medium text-white">Eliminando...</p>
    </div>
  </div>
</AdminLayout>

<script>
const deleteBtn = document.getElementById('delete-book-btn')
const BOOK_ID = Number(deleteBtn?.dataset.bookId)
const deleteModal = document.getElementById('delete-modal')
const loadingOverlay = document.getElementById('loading-overlay')
const cancelDelete = document.getElementById('cancel-delete')
const confirmDelete = document.getElementById('confirm-delete')
const deleteImageCheck = document.getElementById('modal-delete-image') as HTMLInputElement

deleteBtn?.addEventListener('click', () => {
  deleteModal.classList.remove('hidden')
})

function closeModal() {
  deleteModal.classList.add('hidden')
}

cancelDelete?.addEventListener('click', closeModal)
deleteModal.addEventListener('click', (e) => {
  if (e.target === deleteModal) closeModal()
})

confirmDelete?.addEventListener('click', async () => {
  deleteModal.classList.add('hidden')
  loadingOverlay.classList.remove('hidden')

  try {
    const res = await fetch(`/api/admin/books/${BOOK_ID}?_method=DELETE`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ delete_image: deleteImageCheck.checked }),
    })
    if (!res.ok) {
      const data = await res.json()
      loadingOverlay.classList.add('hidden')
      alert(data.error || 'Error al eliminar')
      return
    }
    window.location.href = '/admin/books'
  } catch {
    loadingOverlay.classList.add('hidden')
    alert('Error al eliminar el libro')
  }
})
</script>
