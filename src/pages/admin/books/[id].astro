---
import AdminLayout from '../../../layouts/AdminLayout.astro'
import BookForm from '../../../components/admin/BookForm.vue'
import { getServerSupabase } from '../../../lib/auth'
import { getServerProfile } from '../../../lib/profiles'

const supabase = getServerSupabase(Astro.request, (name, value, options) => {
  Astro.cookies.set(name, value, options as any)
})
const profile = await getServerProfile(supabase)
if (!profile || profile.role !== 'admin') return Astro.redirect('/')

const { id } = Astro.params
const bookId = Number(id)
const { data: book } = await supabase.from('books').select('*').eq('id', bookId).single()

if (!book) {
  return Astro.redirect('/admin/books')
}

const { data: collections } = await supabase.from('collections').select('id, name').order('name')
const { data: categories } = await supabase.from('categories').select('id, name, collection_id').order('name')
---

<AdminLayout>
  <title>Editar libro — Admin</title>

  <div class="max-w-2xl">
    <div class="flex items-center justify-between mb-6">
      <div class="flex items-center gap-3">
        <a href="/admin/books" class="text-text-muted hover:text-text-primary transition-colors">&larr;</a>
        <h1 class="font-heading text-2xl font-bold tracking-tight">Editar libro</h1>
      </div>
      <form
        method="POST"
        action={`/api/admin/books/${bookId}?_method=DELETE`}
        onsubmit="return confirm('¿Eliminar este libro? Esta acción no se puede deshacer.')"
        class="flex flex-col items-end gap-2"
      >
        <label class="flex items-center gap-2 cursor-pointer select-none">
          <input type="checkbox" name="delete_image" value="true" class="rounded border-border accent-accent" />
          <span class="text-xs text-text-muted">Eliminar también la imagen del almacenamiento</span>
        </label>
        <button
          type="submit"
          class="cursor-pointer rounded-lg border border-red-500/20 px-3 py-1.5 text-xs font-medium text-red-400 hover:bg-red-500/5 transition-colors"
        >
          Eliminar libro
        </button>
      </form>
    </div>
    <BookForm client:load />
    <script id="book-data" type="application/json" set:html={JSON.stringify({
      title: book.title,
      author: book.author,
      slug: book.slug,
      description: book.description ?? '',
      price: String(book.price),
      coverUrl: book.cover_url ?? '',
      category_id: book.category_id,
      isVisible: book.is_visible ?? true,
      manualBestSeller: book.manual_best_seller ?? false,
    })}></script>
    <script id="collections-data" type="application/json" set:html={JSON.stringify(collections ?? [])}></script>
    <script id="categories-data" type="application/json" set:html={JSON.stringify(categories ?? [])}></script>
  </div>
</AdminLayout>
