---
import AdminLayout from '../../../layouts/AdminLayout.astro'
import BookForm from '../../../components/admin/BookForm.vue'
import { getServerSupabase } from '../../../lib/auth'
import { getServerProfile } from '../../../lib/profiles'

const supabase = getServerSupabase(Astro.request, (name, value, options) => {
  Astro.cookies.set(name, value, options as any)
})
const profile = await getServerProfile(supabase)
if (!profile || profile.role !== 'admin') return Astro.redirect('/')

const { data: collections } = await supabase.from('collections').select('id, name').order('name')
const { data: categories } = await supabase.from('categories').select('id, name, collection_id').order('name')
---

<AdminLayout>
  <title>Nuevo libro — Admin</title>

  <div class="max-w-2xl">
    <h1 class="font-heading text-2xl font-bold tracking-tight mb-6">Nuevo libro</h1>
    <BookForm client:only="vue" />
    <script id="collections-data" type="application/json" set:html={JSON.stringify(collections ?? [])}></script>
    <script id="categories-data" type="application/json" set:html={JSON.stringify(categories ?? [])}></script>
  </div>
</AdminLayout>
