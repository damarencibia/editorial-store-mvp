---
import AdminLayout from '../../../layouts/AdminLayout.astro'
import DataTable from '../../../components/admin/DataTable.vue'
import { getServerSupabase } from '../../../lib/auth'
import { getServerProfile } from '../../../lib/profiles'

const supabase = getServerSupabase(Astro.request, (name, value, options) => {
  Astro.cookies.set(name, value, options as any)
})
const profile = await getServerProfile(supabase)
if (!profile || profile.role !== 'admin') return Astro.redirect('/')

const { data: books } = await supabase.from('books').select('*, categories(name), authors!left(name)').order('title')

const mappedBooks = (books ?? []).map((b: any) => {
  const price = '$' + (b.price / 100).toFixed(2)
  const date = new Date(b.created_at).toLocaleDateString('es-ES')
  let trendingLabel = ''
  if (b.manual_trending) {
    trendingLabel = 'Manual'
  } else if (b.is_trending) {
    trendingLabel = 'Auto'
  }
  return {
    id: b.id,
    title: b.title,
    author: b.authors?.name ?? '-',
    publisher: b.publisher ?? '-',
    price,
    created_at: date,
    slug: b.slug,
    cover: b.cover_url,
    category: b.categories?.name ?? '-',
    sales_count: b.sales_count ?? 0,
    is_visible: b.is_visible ?? true,
    trending: trendingLabel,
  }
})

const columns = [
  { key: 'cover', label: 'Portada', type: 'image' },
  { key: 'title', label: 'Título' },
  { key: 'author', label: 'Autor' },
  { key: 'publisher', label: 'Editorial' },
  { key: 'category', label: 'Categoría' },
  { key: 'price', label: 'Precio' },
  { key: 'sales_count', label: 'Ventas' },
  { key: 'trending', label: 'Trending' },
  { key: 'created_at', label: 'Creado' },
]

const actions = [
  { type: 'toggle', label: 'Mostrar', labelAlt: 'Ocultar', key: 'is_visible', apiAction: 'toggle_visibility' },
  { type: 'link', label: 'Editar', href: '/admin/books/{id}' },
]

const selectable = true
const bulkActions = [
  { action: 'toggle_visibility', label: 'Mostrar/Ocultar' },
  { action: 'delete', label: 'Eliminar', variant: 'danger' },
]
---

<AdminLayout>
  <title>Libros — Admin</title>

  <div class="max-w-5xl">
    <div class="flex items-center justify-between mb-6">
      <h1 class="font-heading text-2xl font-bold tracking-tight">Libros</h1>
      <a
        href="/admin/books/new"
        class="rounded-lg bg-accent px-4 py-2 text-sm font-medium text-white hover:bg-accent/90 transition-colors"
      >
        + Nuevo libro
      </a>
    </div>

    <DataTable
      client:load
      emptyText="No hay libros registrados."
    />
    <script id="books-data" type="application/json" set:html={JSON.stringify({ columns, rows: mappedBooks, actions, selectable, bulkActions })}></script>
  </div>
</AdminLayout>
