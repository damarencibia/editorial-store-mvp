---
import AdminLayout from '../../layouts/AdminLayout.astro'
import DataTable from '../../components/admin/DataTable.vue'
import { getServerSupabase } from '../../lib/auth'
import { getServerProfile } from '../../lib/profiles'

const supabase = getServerSupabase(Astro.cookies as any)
const profile = await getServerProfile(supabase)
if (!profile || profile.role !== 'admin') return Astro.redirect('/')

const { data: customers } = await supabase
  .from('profiles')
  .select('*')
  .order('created_at', { ascending: false })

const mappedCustomers = (customers ?? []).map((c) => ({
  id: c.id,
  email: c.email,
  role: c.role === 'admin' ? 'Admin' : 'Cliente',
  created_at: new Date(c.created_at).toLocaleDateString('es-ES'),
}))
---

<AdminLayout>
  <title>Clientes — Admin</title>

  <div class="max-w-5xl">
    <h1 class="font-heading text-2xl font-bold tracking-tight mb-6">Clientes</h1>

    <DataTable
      client:only="vue"
      columns={[
        { key: 'email', label: 'Email' },
        { key: 'role', label: 'Rol' },
        { key: 'created_at', label: 'Registrado' },
      ]}
      rows={mappedCustomers}
      emptyText="No hay clientes registrados."
    />
  </div>
</AdminLayout>
