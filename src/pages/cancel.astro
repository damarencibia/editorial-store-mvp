---
import StoreLayout from '../layouts/StoreLayout.astro'
---

<StoreLayout>
  <div class="flex flex-col items-center justify-center py-20 text-center">
    <div class="mb-6 flex h-16 w-16 items-center justify-center rounded-full bg-yellow-500/10">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-yellow-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="10" />
        <line x1="15" y1="9" x2="9" y2="15" />
        <line x1="9" y1="9" x2="15" y2="15" />
      </svg>
    </div>
    <h1 class="font-heading text-3xl font-bold tracking-tight mb-2">Payment Cancelled</h1>
    <p class="text-text-muted mb-8 max-w-md">
      Your payment was cancelled. No charges have been made. You can try again whenever you're ready.
    </p>
    <a
      href="/"
      class="rounded-lg bg-accent px-6 py-2.5 text-sm font-medium text-white hover:bg-accent/90 transition-colors"
    >
      Back to Catalog
    </a>
  </div>
</StoreLayout>
