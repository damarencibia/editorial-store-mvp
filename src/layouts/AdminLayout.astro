---
import BaseLayout from './BaseLayout.astro'
import { getServerSupabase } from '../lib/auth'
import { getServerProfile } from '../lib/profiles'

const supabase = getServerSupabase(Astro.request, (name, value, options) => {
  Astro.cookies.set(name, value, options as any)
})
const { data: { user } } = await supabase.auth.getUser()

if (!user) {
  return Astro.redirect('/auth/login')
}

const profile = await getServerProfile(supabase)

const isAdmin = profile?.role === 'admin'

if (!isAdmin) {
  return Astro.redirect('/')
}

const path = Astro.url.pathname
const initial = user.email?.charAt(0).toUpperCase() ?? '?'
const displayName = user.email?.split('@')[0] ?? 'User'

const navItems = [
  { href: '/admin', label: 'Dashboard', match: (p: string) => p === '/admin' },
  { href: '/admin/books', label: 'Libros', match: (p: string) => p.startsWith('/admin/books') },
  { href: '/admin/orders', label: 'Órdenes', match: (p: string) => p === '/admin/orders' },
  { href: '/admin/customers', label: 'Clientes', match: (p: string) => p === '/admin/customers' },
]
---

<BaseLayout>
  <slot name="head" slot="head" />
  <title>Admin — Editorial</title>

  <div class="flex min-h-screen">
    <!-- Mobile backdrop -->
    <div id="sidebar-backdrop" class="fixed inset-0 z-30 bg-black/50 hidden lg:hidden" onclick="closeSidebar()" />

    <!-- Sidebar -->
    <aside id="admin-sidebar" class="fixed lg:static inset-y-0 left-0 z-40 w-60 -translate-x-full lg:translate-x-0 transition-transform duration-200 flex flex-col border-r border-border bg-surface-2 p-4">
      <div class="flex items-center justify-between mb-8">
        <a href="/admin" class="font-heading text-lg font-bold text-text-primary hover:text-accent transition-colors">
          Editorial
        </a>
        <button onclick="closeSidebar()" class="lg:hidden cursor-pointer text-text-muted hover:text-text-primary p-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </button>
      </div>

      <nav class="flex flex-col gap-1 flex-1">
        {navItems.map((item) => (
          <a
            href={item.href}
            onclick="closeSidebar()"
            class:list={[
              'rounded-lg px-3 py-2 text-sm transition-colors',
              item.match(path)
                ? 'bg-accent/10 text-accent font-medium'
                : 'text-text-muted hover:text-text-primary hover:bg-surface-3',
            ]}
          >
            {item.label}
          </a>
        ))}
      </nav>

      <div class="pt-4 border-t border-border">
        <div class="flex items-center gap-2 px-3 py-2">
          <div class="flex h-7 w-7 items-center justify-center rounded-full bg-accent/10 text-accent text-xs font-bold uppercase">
            {initial}
          </div>
          <div class="flex-1 min-w-0">
            <p class="text-xs font-medium truncate">{displayName}</p>
            <span class="text-[10px] uppercase tracking-wider text-accent font-semibold">Admin</span>
          </div>
        </div>
        <form method="POST" action="/api/auth/signout" class="mt-1">
          <button type="submit" class="w-full rounded-lg px-3 py-1.5 text-xs text-text-muted hover:text-red-400 hover:bg-red-500/5 transition-colors text-left cursor-pointer">
            Cerrar sesión
          </button>
        </form>
      </div>
    </aside>

    <div class="flex-1 flex flex-col min-w-0">
      <header class="lg:hidden border-b border-border bg-surface-1/80 backdrop-blur-md px-4 py-3 flex items-center justify-between">
        <button onclick="openSidebar()" class="cursor-pointer text-text-muted hover:text-text-primary p-1 -ml-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="4" y1="6" x2="20" y2="6" />
            <line x1="4" y1="12" x2="20" y2="12" />
            <line x1="4" y1="18" x2="20" y2="18" />
          </svg>
        </button>
        <a href="/admin" class="font-heading text-lg font-bold">Editorial</a>
        <form method="POST" action="/api/auth/signout">
          <button type="submit" class="text-xs text-text-muted hover:text-red-400 transition-colors cursor-pointer">Salir</button>
        </form>
      </header>

      <main class="flex-1 p-4 sm:p-6 lg:p-8">
        <slot />
      </main>
    </div>
  </div>

  <script>
    function openSidebar() {
      document.getElementById('admin-sidebar').classList.remove('-translate-x-full')
      document.getElementById('sidebar-backdrop').classList.remove('hidden')
      document.body.style.overflow = 'hidden'
    }
    function closeSidebar() {
      document.getElementById('admin-sidebar').classList.add('-translate-x-full')
      document.getElementById('sidebar-backdrop').classList.add('hidden')
      document.body.style.overflow = ''
    }
  </script>
</BaseLayout>
