---
import BaseLayout from './BaseLayout.astro'
import AdminSidebar from '../components/admin/AdminSidebar.vue'
import { getServerSupabase } from '../lib/auth'
import { getServerProfile } from '../lib/profiles'

const supabase = getServerSupabase(Astro.request, (name, value, options) => {
  Astro.cookies.set(name, value, options as any)
})
const { data: { user } } = await supabase.auth.getUser()

if (!user) {
  return Astro.redirect('/auth/login')
}

const profile = await getServerProfile(supabase)

const isAdmin = profile?.role === 'admin'

if (!isAdmin) {
  return Astro.redirect('/')
}

const path = Astro.url.pathname
const initial = user.email?.charAt(0).toUpperCase() ?? '?'
const displayName = user.email?.split('@')[0] ?? 'User'
---

<BaseLayout>
  <slot name="head" slot="head" />
  <title>Admin — Editorial</title>

  <div class="flex min-h-screen">
    <AdminSidebar
      client:load
      currentPath={path}
      displayName={displayName}
      initial={initial}
    />

    <div class="flex-1 flex flex-col min-w-0">
      <header class="lg:hidden border-b border-border bg-surface-1/80 backdrop-blur-md px-4 py-3 flex items-center justify-between">
        <button id="sidebar-toggle-btn" class="cursor-pointer text-text-muted hover:text-text-primary p-1 -ml-1">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="4" y1="6" x2="20" y2="6" />
            <line x1="4" y1="12" x2="20" y2="12" />
            <line x1="4" y1="18" x2="20" y2="18" />
          </svg>
        </button>
        <a href="/admin" class="flex items-center gap-2">
          <img src="/images/logo.png" alt="Editorial" class="h-8 w-8 rounded-full" />
          <span class="font-heading text-lg font-bold">Editorial</span>
        </a>
        <form method="POST" action="/api/auth/signout">
          <button type="submit" class="text-xs text-text-muted hover:text-red-400 transition-colors cursor-pointer">Salir</button>
        </form>
      </header>

      <main class="flex-1 p-4 sm:p-6 lg:p-8">
        <slot />
      </main>
    </div>
  </div>

  <script is:inline>
    document.getElementById('sidebar-toggle-btn')?.addEventListener('click', () => {
      window.dispatchEvent(new CustomEvent('toggle-admin-sidebar'))
    })
  </script>
</BaseLayout>
