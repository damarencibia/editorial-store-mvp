---
import BaseLayout from './BaseLayout.astro'
import CartIcon from '../components/store/CartIcon.vue'
import CartDrawer from '../components/store/CartDrawer.vue'
import AuthStatus from '../components/store/AuthStatus.vue'
import StoreSidebar from '../components/store/StoreSidebar.vue'
import GlobalSearch from '../components/store/GlobalSearch.vue'
---

<BaseLayout>
  <slot name="head" slot="head" />

  <header class="sticky top-0 z-40 border-b border-border bg-surface-1/80 backdrop-blur-md">
    <div class="flex items-center justify-between px-4 sm:px-6 lg:px-8 py-3">
      <div class="flex items-center gap-3">
        <button
          id="sidebar-toggle-btn"
          class="cursor-pointer text-text-muted hover:text-text-primary p-1.5 -ml-1.5 rounded-lg hover:bg-surface-3 transition-colors"
          aria-label="Abrir menú"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="4" y1="6" x2="20" y2="6" />
            <line x1="4" y1="12" x2="20" y2="12" />
            <line x1="4" y1="18" x2="20" y2="18" />
          </svg>
        </button>
        <a href="/" class="flex items-center gap-2.5 shrink-0">
          <img src="/images/logo.png" alt="Arraigo Editorial" class="h-9 w-9 rounded-full" />
          <span class="font-heading text-xl font-bold tracking-tight text-text-primary">
            Arraigo Editorial
          </span>
        </a>
      </div>

      <div class="hidden sm:block flex-1 max-w-md mx-auto sm:mx-4 lg:mx-8">
        <GlobalSearch client:only="vue" />
      </div>
      <div class="sm:hidden">
        <GlobalSearch client:only="vue" />
      </div>

      <div class="flex items-center gap-2">
        <AuthStatus client:only="vue" />
        <CartIcon client:only="vue" />
      </div>
    </div>
  </header>

  <slot name="hero" />

  <main class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
    <slot />
  </main>

  <footer class="border-t border-border mt-24">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        <div class="col-span-2 md:col-span-1">
          <a href="/" class="flex items-center gap-2.5">
            <img src="/images/logo.png" alt="Arraigo Editorial" class="h-8 w-8 rounded-full" />
            <span class="font-heading text-lg font-bold text-text-primary hover:text-accent transition-colors">Arraigo Editorial</span>
          </a>
          <p class="mt-2 text-sm text-text-dim">Palabras que echan raíces.</p>
        </div>
        <div>
          <h4 class="text-xs font-semibold uppercase tracking-wider text-text-muted mb-3">Navegar</h4>
          <ul class="space-y-2">
            <li><a href="/" class="text-sm text-text-dim hover:text-text-primary transition-colors">Catálogo</a></li>
            <li><a href="/colecciones" class="text-sm text-text-dim hover:text-text-primary transition-colors">Colecciones</a></li>
            <li><a href="/tendencias" class="text-sm text-text-dim hover:text-text-primary transition-colors">Trending</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-xs font-semibold uppercase tracking-wider text-text-muted mb-3">Legal</h4>
          <ul class="space-y-2">
            <li><a href="#" class="text-sm text-text-dim hover:text-text-primary transition-colors">Términos</a></li>
            <li><a href="#" class="text-sm text-text-dim hover:text-text-primary transition-colors">Privacidad</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-xs font-semibold uppercase tracking-wider text-text-muted mb-3">Contacto</h4>
          <ul class="space-y-2">
            <li><a href="mailto:hola@editorial.com" class="text-sm text-text-dim hover:text-text-primary transition-colors">hola@editorial.com</a></li>
          </ul>
        </div>
      </div>
      <div class="mt-10 pt-6 border-t border-border text-center text-xs text-text-dim">
        &copy; {new Date().getFullYear()} Arraigo Editorial. Todos los derechos reservados.
      </div>
    </div>
  </footer>

  <StoreSidebar client:only="vue" />
  <CartDrawer client:only="vue" />
</BaseLayout>

<script is:inline>
  document.getElementById('sidebar-toggle-btn')?.addEventListener('click', () => {
    window.dispatchEvent(new CustomEvent('toggle-store-sidebar'))
  })
</script>
